{
  "ConnectionStrings": {
    "DefaultConnection": ""
  },
  "JwtSettings": {
    "Secret": "",
    "Issuer": "AssetManagement.API",
    "Audience": "AssetManagement.Client",
    "ExpirationInMinutes": 60,
    "RefreshTokenExpirationInDays": 7
  },
  "DataRetention": {
    "CategoriesRetentionHours": 24,
    "LocationsRetentionHours": 24,
    "UsersRetentionDays": 30,
    "AssetsRetentionDays": 90,
    "AuditLogsRetentionHours": 1,
    "NotificationEnabled": true,
    "NotificationHoursBeforeDeletion": 1
  },
  "Cors": {
    "AllowedOrigins": []
  },
  "SeedData": {
    "Enabled": false
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
